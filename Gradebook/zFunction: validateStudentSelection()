int validateStudentSelection()
{
    int uInput = 0;
    printf("Select a student by integer to manage their gradebook: ");
    while (scanf_s("%d", &uInput) != 1 || uInput < 0 || uInput > STUDENT_LIMIT)
    {
        printf("\n");
        printf("Invalid input. Select an integer from 0 - %d: ", STUDENT_LIMIT);
        while (getchar() != '\n'); // Clear input buffer. Otherwise will get infinite loop when invalid input. 
        // Also from stack overflow
    }
    return uInput;
}

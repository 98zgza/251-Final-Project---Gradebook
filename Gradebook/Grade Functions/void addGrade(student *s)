#include <stdio.h>
#include "student.h"


// Adds grade to a student. Checks if gradebook is at capacity and returns if so.
// Auto generates assignment name from 0 - assignment count
// Runs validateGradeInput to ensure integer is entered and within grade limits.
// At end, iterates gradecount and print success message.
void addGrade(Student* s)
{
    // Set count track to number of inputted grades
    int countTrack = s->grade_count;

    // Check if gradebook is at capacity, return if full
    if (s->grade_count >= GRADE_LIMIT)
    {
        printf("Sorry, grade book is max capacity!");
        return;
    }

    //Auto generate assignment name, while I figure out how to  request uInput
    // sprintf_s(destination, size, format, val)
    sprintf_s(s->grades[countTrack].assignment_name, NAME_LIMIT, "Assignment %d", countTrack);

    int tempGrade = validateGradeInput();

    // Upgrade appropriate value in grades array and iterate grade_count.
    s->grades[countTrack].grade = tempGrade;
    s->grade_count++;
    printf("Success, grade added!\n");

} // End of addGrade(Student *s)
